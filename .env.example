# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Notion tracker
NOTION_API_KEY=your_notion_integration_secret_here
NOTION_DATABASE_ID=your_notion_database_id_here
    
# Notion property names. Change only if your database uses different labels.
NOTION_TITLE_PROPERTY=Name
NOTION_OWNER_PROPERTY=Owner
NOTION_DUE_DATE_PROPERTY=Due Date
NOTION_STATUS_PROPERTY=Status
NOTION_STATUS_DONE_VALUES=Done,Complete,Completed,Archived
NOTION_SOURCE_PROPERTY=Source Meeting

# Python command used by Next.js API routes.
PYTHON_BIN=python3
